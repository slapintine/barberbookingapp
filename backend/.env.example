NODE_ENV=development
PORT=5000
HOST=127.0.0.1
LOG_LEVEL=debug
CLIENT_URL=http://localhost:5173
DEV_CLIENT_URL=http://127.0.0.1:5177,http://localhost:5177
ALLOW_LOCAL_DEV_ORIGINS=true
APP_PUBLIC_URL=http://localhost:5173
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:5000/api
JWT_SECRET=replace-this-with-at-least-32-random-characters
DB_CLIENT=sqlite
DB_PATH=./src/db/barber_app.sqlite
# Mount this directory on persistent storage in production.
IMAGE_STORAGE_DIR=./uploads

# Production must use PostgreSQL and must not allow localhost origins:
# NODE_ENV=production
# APP_PUBLIC_URL=https://queless.org
# APP_URL=https://queless.org
# FRONTEND_URL=https://queless.org
# BASE_URL=https://queless.org
# API_BASE_URL=https://queless.org/api
# CLIENT_URL=https://queless.org,https://www.queless.org
# DEV_CLIENT_URL=
# ALLOW_LOCAL_DEV_ORIGINS=false
# DB_CLIENT=postgres
# DATABASE_URL=postgresql://user:password@host:5432/database
# DATABASE_SSL=true

# Firebase Cloud Messaging Admin. Store the full service account JSON as one env value.
FIREBASE_SERVICE_ACCOUNT_JSON=

AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SHORTCODE=
AFRICASTALKING_ENV=sandbox
AFRICASTALKING_LIFECYCLE_SMS_ENABLED=false
AFRICASTALKING_SMS_AUTO_REPLY_ENABLED=false
AFRICASTALKING_DEFAULT_AUTO_REPLY=Thank you for contacting Queless. We have received your message.

# Optional: mobile money collections and payouts.
# Use `sandbox` for MTN sandbox integration or `mock` for local fake flows.
MOBILE_MONEY_MODE=sandbox
ENABLE_MOCK_PAYMENTS=false
MOBILE_MONEY_DEFAULT_PROVIDER=mtn
MOBILE_MONEY_CURRENCY=EUR
MOBILE_MONEY_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOBILE_MONEY_API_KEY=
MOBILE_MONEY_API_SECRET=
MOBILE_MONEY_COLLECTION_URL=
MOBILE_MONEY_VERIFICATION_URL=
MOBILE_MONEY_DISBURSEMENT_URL=
MOBILE_MONEY_CALLBACK_URL=
MTN_WEBHOOK_URL=
AIRTEL_CALLBACK_URL=
AIRTEL_WEBHOOK_URL=
MOBILE_MONEY_WEBHOOK_TOKEN=
PROVIDER_PROMO_FREE_CODE=
PROVIDER_PROMO_20_CODE=
PROVIDER_PROMO_EXPIRES_AT=
CUSTOMER_PREMIUM_PROMO_FREE_CODE=
CUSTOMER_PREMIUM_PROMO_20_CODE=
CUSTOMER_PREMIUM_PROMO_EXPIRES_AT=
MTN_API_USER_ID=
MTN_API_KEY=
# Secret/password-style value. This is not used as the MTN API user ID.
MTN_API_SECRET=
MTN_SUBSCRIPTION_KEY=
MTN_COLLECTION_SUBSCRIPTION_KEY=
MTN_DISBURSEMENT_SUBSCRIPTION_KEY=
MTN_PROVISIONING_SUBSCRIPTION_KEY=
CALLBACK_HOST=
MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_TARGET_ENVIRONMENT=sandbox
MTN_CURRENCY=EUR
MTN_COLLECTION_URL=https://sandbox.momodeveloper.mtn.com/collection/v1_0/requesttopay
MTN_VERIFICATION_URL=https://sandbox.momodeveloper.mtn.com/collection/v1_0/requesttopay
MTN_DISBURSEMENT_URL=https://sandbox.momodeveloper.mtn.com/disbursement/v1_0/transfer
AIRTEL_ENABLED=false
AIRTEL_API_KEY=
AIRTEL_API_SECRET=
AIRTEL_COLLECTION_URL=
AIRTEL_VERIFICATION_URL=
AIRTEL_DISBURSEMENT_URL=
RESEND_API_KEY=
EMAIL_FROM=Queless <info@queless.org>

# Provider Coach is rule-based and uses internal Queless data only.
