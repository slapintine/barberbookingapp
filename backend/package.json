{
  "name": "queless-backend",
  "version": "1.0.0",
  "description": "Clean backend for Queless",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "check": "node --check src/app.js",
    "test": "node --test",
    "db:migrate": "node src/db/migrate.js",
    "db:import-sqlite": "node src/db/importSqliteToPostgres.js",
    "check:deployment": "node src/scripts/deploymentReadinessCheck.js",
    "audit:paid-features": "node src/scripts/auditPaidFeatureEntitlements.js",
    "cleanup:paid-features": "node src/scripts/auditPaidFeatureEntitlements.js --remediate --confirm-paid-feature-cleanup",
    "audit:provider-readiness": "node src/scripts/providerPublicationReadiness.js",
    "audit:demo-businesses": "node src/scripts/cleanupDemoBusinesses.js",
    "migrate:provider-images": "node src/scripts/migrateProviderImages.js",
    "cleanup:demo-businesses": "node src/scripts/cleanupDemoBusinesses.js --delete --confirm-demo-cleanup",
    "qa:seed-plans": "node src/scripts/seedPlanQaFixtures.js",
    "qa:verify-plans": "node src/scripts/verifyPlanQaFixtures.js",
    "user:upsert": "node src/scripts/upsertUser.js",
    "mtn:check": "node src/scripts/checkMtnIntegration.js",
    "mtn:provision": "node src/scripts/provisionMtnSandbox.js"
  },
  "dependencies": {
    "africastalking": "^0.7.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "queless": "file:..",
    "resend": "^6.12.3",
    "socket.io": "^4.8.3",
    "sqlite3": "^6.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "pino-pretty": "^13.1.3"
  },
  "overrides": {
    "axios": "^1.16.1",
    "lodash": "^4.18.1",
    "uuid": "^11.1.1"
  }
}
